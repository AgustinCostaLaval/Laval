    <style>
        @@font-face {
            font-family: "Barlow Condensed";
            src: url("/fonts/BarlowCondensed-Regular.ttf") format("truetype");
            font-weight: 400;
            font-style: normal;
            font-display: swap;
        }

        @@font-face {
            font-family: "Barlow Condensed";
            src: url("/fonts/BarlowCondensed-SemiBold.ttf") format("truetype");
            font-weight: 600;
            font-style: normal;
            font-display: swap;
        }

        @@font-face {
            font-family: "Barlow Condensed";
            src: url("/fonts/BarlowCondensed-Bold.ttf") format("truetype");
            font-weight: 700;
            font-style: normal;
            font-display: swap;
        }

        html,
        body,
        #root,
        #root * {
            font-family: "Barlow Condensed", "Arial Narrow", Arial, sans-serif !important;
        }

        header {
            min-height: 98px !important;
            position: relative;
        }

        header img,
        header svg {
            transform: scale(1.1);
            transform-origin: left center;
        }

        .laval-brand-link {
            position: absolute !important;
            left: clamp(12px, 2vw, 28px);
            top: 50%;
            transform: translateY(-50%);
            display: inline-flex !important;
            align-items: center;
            width: clamp(170px, 16vw, 240px);
            z-index: 4;
        }

        .laval-custom-logo {
            width: 100% !important;
            height: auto !important;
            max-width: 100% !important;
            max-height: 78px !important;
            object-fit: contain;
            transform: none !important;
        }

        .laval-phone-link {
            position: static !important;
            right: auto !important;
            top: auto !important;
            transform: none !important;
            margin: 0 !important;
            z-index: auto;
        }

        @@media (max-width: 991px) {
            .laval-brand-link {
                position: static !important;
                left: auto !important;
                top: auto !important;
                transform: none !important;
                width: auto !important;
            }
        }

        @@media (min-width: 992px) {
            header a,
            header nav a,
            header button,
            header span,
            header p,
            header div {
                font-size: 1.34rem !important;
                letter-spacing: 0.02em;
            }

            header nav ul,
            header [role="navigation"] ul,
            header nav [class*="menu"] {
                display: flex !important;
                align-items: center !important;
                gap: 2.3rem !important;
            }

            header nav li,
            header [role="navigation"] li {
                margin: 0 !important;
            }

            header nav a,
            header [role="navigation"] a {
                padding-inline: 0.1rem !important;
                font-weight: 700 !important;
                white-space: nowrap;
            }

            header [class*="phone"],
            header [class*="contact"] {
                font-size: 1.08rem !important;
                padding: 0.52rem 1.05rem !important;
            }

            .laval-phone-link {
            position: absolute !important;
            right: clamp(12px, 2vw, 28px) !important;
            top: 50% !important;
            transform: translateY(-50%) !important;
            margin: 0 !important;
            z-index: 7;
            }

            header nav,
            header [role="navigation"] {
                position: absolute !important;
                left: 50% !important;
                top: 50% !important;
                transform: translate(-50%, -50%) !important;
                width: max-content !important;
                z-index: 7;
            }

            header nav ul,
            header [role="navigation"] ul,
            header nav [class*="menu"] {
                justify-content: center !important;
                padding-left: 0 !important;
            }

        }

    </style>
</head>
<body>
    <div id="root"></div>
    <script>
        (function () {
            const FIX_MAP = new Map([
                ["Ã¡", "á"], ["Ã©", "é"], ["Ã­", "í"], ["Ã³", "ó"], ["Ãº", "ú"],
                ["Ã", "Á"], ["Ã‰", "É"], ["Ã", "Í"], ["Ã“", "Ó"], ["Ãš", "Ú"],
                ["Ã±", "ñ"], ["Ã‘", "Ñ"], ["Ã¼", "ü"], ["Ãœ", "Ü"],
                ["Â¿", "¿"], ["Â¡", "¡"], ["â", "\""], ["â", "\""], ["â", "'"],
                ["â", "–"], ["â", "—"], ["Â°", "°"], ["Â", ""]
            ]);

            function fixMojibake(value) {
                if (!value) return value;
                let out = value;
                for (const [bad, good] of FIX_MAP.entries()) {
                    out = out.split(bad).join(good);
                }
                return out;
            }

            function fixRenderedTexts() {
                const walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT);
                while (walker.nextNode()) {
                    const node = walker.currentNode;
                    if (!node || !node.nodeValue) continue;
                    const fixed = fixMojibake(node.nodeValue);
                    if (fixed !== node.nodeValue) node.nodeValue = fixed;
                }

                const attrs = ["title", "placeholder", "aria-label"];
                const attrCandidates = document.querySelectorAll("[title], [placeholder], [aria-label]");
                attrCandidates.forEach((el) => {
                    attrs.forEach((attr) => {
                        if (!el.hasAttribute(attr)) return;
                        const current = el.getAttribute(attr);
                        const fixed = fixMojibake(current);
                        if (fixed !== current) el.setAttribute(attr, fixed);
                    });
                });
            }

            function normalizeText(value) {
                return fixMojibake(value || "")
                    .toLowerCase()
                    .normalize("NFD")
                    .replace(/[\u0300-\u036f]/g, "")
                    .replace(/\s+/g, " ")
                    .trim();
            }

            function removeTrustSection() {
                const headings = document.querySelectorAll("h1, h2, h3, h4, h5, h6");
                for (const heading of headings) {
                    const text = normalizeText(heading.textContent);
                    if (!text.includes("conf") || !text.includes("nosotros")) continue;

                    const block = heading.closest("section") || heading.closest("article") || heading.closest("div");
                    if (!block) continue;

                    block.remove();
                    return true;
                }
                return false;
            }

            function decodeURIComponentSafe(value) {
                try {
                    return decodeURIComponent(value);
                } catch {
                    return value;
                }
            }

            function decodeRepeated(value) {
                let out = value || "";
                for (let i = 0; i < 2; i++) {
                    const decoded = decodeURIComponentSafe(out);
                    if (decoded === out) break;
                    out = decoded;
                }
                return out;
            }

            function fixWhatsAppLinks() {
                const candidates = document.querySelectorAll(
                    "a[href*='wa.me'], a[href*='whatsapp'], [onclick*='wa.me'], [onclick*='whatsapp']"
                );

                candidates.forEach((el) => {
                    if (el.hasAttribute("onclick")) {
                        const onclickValue = el.getAttribute("onclick");
                        const fixedOnclick = fixMojibake(onclickValue);
                        if (fixedOnclick !== onclickValue) {
                            el.setAttribute("onclick", fixedOnclick);
                        }
                    }

                    if (!el.hasAttribute("href")) return;
                    const href = el.getAttribute("href");
                    if (!href) return;

                    let url;
                    try {
                        url = new URL(href, window.location.origin);
                    } catch {
                        return;
                    }

                    const host = (url.hostname || "").toLowerCase();
                    if (!host.includes("wa.me") && !host.includes("whatsapp.com")) return;

                    const textParam = url.searchParams.get("text");
                    if (!textParam) return;

                    const decoded = decodeRepeated(textParam);
                    const fixed = fixMojibake(decoded);
                    if (fixed !== decoded) {
                        url.searchParams.set("text", fixed);
                        el.setAttribute("href", url.toString());
                    }
                });
            }

            function getFieldIdentity(field) {
                const labelFor = field.id
                    ? document.querySelector(`label[for="${CSS.escape(field.id)}"]`)?.textContent
                    : "";
                const wrapper = field.closest("div");
                const nearby = wrapper
                    ? Array.from(wrapper.querySelectorAll("label, p, span"))
                          .map((el) => el.textContent)
                          .join(" ")
                    : "";

                return normalizeText(
                    [
                        field.getAttribute("name"),
                        field.getAttribute("id"),
                        field.getAttribute("placeholder"),
                        field.getAttribute("aria-label"),
                        field.closest("label")?.textContent,
                        labelFor,
                        nearby
                    ]
                        .filter(Boolean)
                        .join(" ")
                );
            }

            function getFieldValueByHints(form, selector, hints) {
                const fields = Array.from(form.querySelectorAll(selector));
                for (const field of fields) {
                    const identity = getFieldIdentity(field);
                    if (hints.some((hint) => identity.includes(hint))) {
                        return readFieldValue(field);
                    }
                }

                return "";
            }

            function readFieldValue(field) {
                return (field.value || field.getAttribute("value") || "").trim();
            }

            function extractContactPayload(container) {
                const textarea = container.querySelector("textarea");
                const inputs = Array.from(container.querySelectorAll("input")).filter((field) => {
                    const type = (field.getAttribute("type") || "text").toLowerCase();
                    return !["hidden", "submit", "button", "checkbox", "radio", "file"].includes(type);
                });

                let fullName = getFieldValueByHints(container, "input", ["nombre", "name"]);
                let phone = getFieldValueByHints(container, "input", ["telefono", "whatsapp", "tel"]);
                let email = getFieldValueByHints(container, "input", ["correo", "email", "mail"]);
                let message = getFieldValueByHints(container, "textarea", ["mensaje", "consulta"]);

                const emailInput = container.querySelector('input[type="email"]');
                const phoneInput = container.querySelector('input[type="tel"]');

                if (!email && emailInput) email = readFieldValue(emailInput);
                if (!phone && phoneInput) phone = readFieldValue(phoneInput);

                if ((!fullName || !phone || !email) && inputs.length >= 3) {
                    const ordered = inputs
                        .map((field) => ({
                            field,
                            type: (field.getAttribute("type") || "text").toLowerCase(),
                            value: readFieldValue(field)
                        }))
                        .filter((item) => item.value);

                    const emailItem = ordered.find((item) => item.type === "email" || item.value.includes("@"));
                    const phoneItem = ordered.find((item) =>
                        item.type === "tel" || (item !== emailItem && /\d{6,}/.test(item.value))
                    );
                    const nameItem = ordered.find((item) => item !== emailItem && item !== phoneItem);

                    if (!fullName && nameItem) fullName = nameItem.value;
                    if (!phone && phoneItem) phone = phoneItem.value;
                    if (!email && emailItem) email = emailItem.value;

                    if (!fullName && ordered[0]) fullName = ordered[0].value;
                    if (!phone && ordered[1]) phone = ordered[1].value;
                    if (!email && ordered[2]) email = ordered[2].value;
                }

                if (!message && textarea) message = readFieldValue(textarea);

                return { fullName, phone, email, message };
            }

            function findContactSubmitButton() {
                return Array.from(document.querySelectorAll("button, input[type='submit']")).find((btn) => {
                    const text = normalizeText(btn.textContent || btn.value || "");
                    return text.includes("enviar") && text.includes("consulta");
                });
            }

            function findContactContainer(submitButton) {
                let node = submitButton.parentElement;
                while (node && node !== document.body) {
                    const textarea = node.querySelector("textarea");
                    const inputs = node.querySelectorAll("input");
                    if (textarea && inputs.length >= 2) return node;
                    node = node.parentElement;
                }

                return submitButton.closest("form") || submitButton.parentElement;
            }

            async function sendContactPayload(form, submit, payload) {
                const originalText = submit.textContent || submit.value || "";
                if ("disabled" in submit) submit.disabled = true;
                if ("textContent" in submit) submit.textContent = "Enviando...";

                try {
                    const response = await fetch("/api/contact/send", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify(payload)
                    });

                    const result = await response.json().catch(() => ({}));
                    if (!response.ok || !result.success) {
                        throw new Error(result.message || "No pudimos enviar tu consulta en este momento.");
                    }

                    form.reset();
                    alert("Gracias. Tu consulta fue enviada correctamente.");
                } catch (error) {
                    alert(error.message || "No pudimos enviar tu consulta en este momento.");
                } finally {
                    if ("disabled" in submit) submit.disabled = false;
                    if ("textContent" in submit) submit.textContent = originalText;
                }
            }

            function bindContactSend(container, submit) {
                if (!container || !submit || submit.dataset.lavalMailBound === "1") return false;

                submit.dataset.lavalMailBound = "1";
                let sending = false;

                const handleSend = async (event) => {
                    event.preventDefault();
                    event.stopPropagation();
                    event.stopImmediatePropagation();
                    if (sending) return;

                    const payload = extractContactPayload(container);
                    if (!payload.fullName || !payload.phone || !payload.email || !payload.message) {
                        alert("Completá todos los campos obligatorios.");
                        return;
                    }

                    sending = true;
                    try {
                        const formLike = container.closest("form") || container;
                        await sendContactPayload(formLike, submit, payload);
                    } finally {
                        sending = false;
                    }
                };

                submit.addEventListener("click", handleSend, true);
                const form = container.closest("form");
                if (form) form.addEventListener("submit", handleSend, true);
                return true;
            }

            function wireContactFormSubmission() {
                const submit = findContactSubmitButton();
                if (submit) {
                    const container = findContactContainer(submit);
                    if (bindContactSend(container, submit)) return;
                }

                const forms = Array.from(document.querySelectorAll("form"));
                for (const form of forms) {
                    const formSubmit = form.querySelector("button[type='submit'], input[type='submit'], button");
                    const hasTextarea = !!form.querySelector("textarea");
                    const buttonText = normalizeText((formSubmit?.textContent || formSubmit?.value || ""));
                    if (!hasTextarea || !formSubmit || (!buttonText.includes("consulta") && !buttonText.includes("enviar"))) {
                        continue;
                    }

                    bindContactSend(form, formSubmit);
                }
            }

            function replaceHeaderLogo() {
                const logoPath = "/images/logo/laval-menu-logo.png";
                const header = document.querySelector("header");
                if (!header) return false;

                const brandCandidates = Array.from(header.querySelectorAll("a"))
                    .filter((a) => !a.closest("nav"))
                    .filter((a) => !/\d{2,}/.test(a.textContent || ""));

                if (brandCandidates.length === 0) return false;

                const brandLink = brandCandidates.sort((a, b) =>
                    a.getBoundingClientRect().left - b.getBoundingClientRect().left
                )[0];

                let logoImg = brandLink.querySelector("img.laval-custom-logo");
                if (!logoImg) {
                    brandLink.innerHTML = "";
                    logoImg = document.createElement("img");
                    brandLink.appendChild(logoImg);
                }

                logoImg.src = logoPath;
                logoImg.alt = "Laval Servicios";
                logoImg.className = "laval-custom-logo";
                brandLink.classList.add("laval-brand-link");
                brandLink.style.minWidth = "0";

                const phoneCandidates = Array.from(header.querySelectorAll("a, button"))
                    .filter((el) => /\d{3,}/.test(el.textContent || ""))
                    .filter((el) => !el.querySelector("img"));

                if (phoneCandidates.length > 0) {
                    phoneCandidates[0].classList.add("laval-phone-link");
                }
                return true;
            }

            function boot() {
                fixRenderedTexts();
                fixWhatsAppLinks();
                wireContactFormSubmission();
                removeTrustSection();
                replaceHeaderLogo();

                const observer = new MutationObserver(() => {
                    fixRenderedTexts();
                    fixWhatsAppLinks();
                    wireContactFormSubmission();
                    removeTrustSection();
                    replaceHeaderLogo();
                });

                observer.observe(document.body, { childList: true, subtree: true });
            }

            document.addEventListener("DOMContentLoaded", boot);
        })();
    </script>
</body>
</html>
